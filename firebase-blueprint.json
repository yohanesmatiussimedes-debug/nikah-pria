{
  "entities": {
    "Wish": {
      "title": "Wish",
      "description": "A wedding wish/message from a guest",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Guest name"
        },
        "message": {
          "type": "string",
          "description": "The message content"
        },
        "attendance": {
          "type": "string",
          "enum": ["hadir", "tidak_hadir"],
          "description": "Attendance status"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the wish"
        }
      },
      "required": ["name", "message", "createdAt"]
    }
  },
  "firestore": {
    "wishes": {
      "schema": "Wish",
      "description": "Collection of wedding wishes"
    }
  }
}
