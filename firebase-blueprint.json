{
  "entities": {
    "Wish": {
      "title": "Wish",
      "description": "A guestbook entry with a name, message, and attendance status.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the guest."
        },
        "message": {
          "type": "string",
          "description": "The message or wish from the guest."
        },
        "attendance": {
          "type": "string",
          "enum": ["hadir", "tidak_hadir"],
          "description": "The guest's attendance status."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the wish was created."
        }
      },
      "required": ["name", "message", "attendance", "createdAt"]
    }
  },
  "firestore": {
    "/wishes/{wishId}": {
      "schema": "Wish",
      "description": "Collection of guestbook wishes."
    },
    "/whises2/{wishId}": {
      "schema": "Wish",
      "description": "New collection of guestbook wishes."
    }
  }
}
