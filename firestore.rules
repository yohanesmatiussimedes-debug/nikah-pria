rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: wishes, whises2
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-100 chars) - Guest name
    //   - message: string (required, 1-1000 chars) - Guest wish
    //   - attendance: string (required, 'hadir' or 'tidak_hadir') - Attendance status
    //   - createdAt: timestamp (required) - Creation time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidWish(data) {
      return hasRequiredFields(['name', 'message', 'attendance', 'createdAt']) &&
             hasOnlyAllowedFields(['name', 'message', 'attendance', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 1000 &&
             data.attendance in ['hadir', 'tidak_hadir'] &&
             data.createdAt is timestamp;
    }

    match /wishes/{wishId} {
      // Allow anyone to read wishes (public guestbook)
      allow read: if true;
      
      // Allow anyone to create a wish (no auth required for guestbook)
      // but validate the data strictly
      allow create: if isValidWish(request.resource.data);
      
      // Deny updates and deletes for now to keep the guestbook immutable for guests
      allow update, delete: if false;
    }

    match /whises2/{wishId} {
      // Allow anyone to read wishes (public guestbook)
      allow read: if true;
      
      // Allow anyone to create a wish (no auth required for guestbook)
      // but validate the data strictly
      allow create: if isValidWish(request.resource.data);
      
      // Deny updates and deletes for now to keep the guestbook immutable for guests
      allow update, delete: if false;
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
