rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: wishes
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - message: string (required, 1-1000 chars)
    //   - attendance: string (required, 'hadir' or 'tidak_hadir')
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "https.https.https.https.error@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidWish(data) {
      return data.keys().hasAll(['name', 'message', 'attendance', 'createdAt']) &&
             data.keys().hasOnly(['name', 'message', 'attendance', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 1000 &&
             data.attendance in ['hadir', 'tidak_hadir'] &&
             data.createdAt is timestamp;
    }

    match /wishes/{wishId} {
      // Allow anyone to read wishes
      allow read: if true;
      
      // Allow anyone to create a wish if it's valid
      allow create: if isValidWish(request.resource.data);
      
      // Allow admin to delete wishes
      allow delete: if isAdmin();
      
      // No updates allowed
      allow update: if false;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
